// ============================================================
// Comprehensive AVM test file
// Tests: globals, arithmetic, strings, booleans, nil,
//        tables, user functions, closures, recursion,
//        library functions, relational/logical ops, jumps
// ============================================================


// ---- 1. Globals and basic arithmetic ----------------------
a = 10;
b = 3;

print("=== Arithmetic ===\n");
print(a + b, "\n");      // 13
print(a - b, "\n");      // 7
print(a * b, "\n");      // 30
print(a / b, "\n");      // 3.333333
print(a % b, "\n");      // 1
print(-a,    "\n");       // -10


// ---- 2. String ----------------------------------------
print("=== Strings ===\n");
s = "hello";
print(s, "\n");           // hello
print(typeof(s), "\n");   // string


// ---- 3. Bool / nil ------------------------------------
print("=== Bool / Nil ===\n");
t = true;
f = false;
n = nil;
print(typeof(t), "\n");   // bool
print(typeof(f), "\n");   // bool
print(typeof(n), "\n");   // nil


// ---- 4. Typeof for number and userfunc ----------------
print("=== Typeof ===\n");
print(typeof(42),    "\n");  // number
print(typeof(print), "\n");  // libfunc


// ---- 5. Relational and logical ops --------------------
print("=== Relational ===\n");
if (a > b)   print("a > b\n");           // printed
if (a >= 10) print("a >= 10\n");         // printed
if (b < a)   print("b < a\n");           // printed
if (b <= 3)  print("b <= 3\n");          // printed
if (a == 10) print("a == 10\n");         // printed
if (a != b)  print("a != b\n");          // printed

print("=== Logical ===\n");
if (t and true)  print("t and true\n");  // printed
if (f or  true)  print("f or true\n");   // printed
if (not f)       print("not false\n");   // printed


// ---- 6. While loop ------------------------------------
print("=== While loop ===\n");
i = 0;
while (i < 5) {
    print(i, " ");
    i = i + 1;
}
print("\n");   // 0 1 2 3 4


// ---- 7. For loop --------------------------------------
print("=== For loop ===\n");
sum = 0;
for (j = 1; j <= 10; j = j + 1)
    sum = sum + j;
print(sum, "\n");   // 55


// ---- 8. Nested if / else ------------------------------
print("=== If/Else ===\n");
x = 7;
if (x > 10) {
    print("big\n");
} else if (x > 4) {
    print("medium\n");   // printed
} else {
    print("small\n");
}


// ---- 9. User function – basic -------------------------
print("=== Functions ===\n");
function add(p, q) {
    return p + q;
}
print(add(4, 5), "\n");   // 9
print(add(100, -1), "\n"); // 99


// ---- 10. Recursive function ---------------------------
print("=== Recursion ===\n");
function fact(n) {
    if (n <= 1) return 1;
    return n * fact(n - 1);
}
print(fact(1),  "\n");   // 1
print(fact(5),  "\n");   // 120
print(fact(10), "\n");   // 3628800


// ---- 11. Fibonacci ------------------------------------
print("=== Fibonacci ===\n");
function fib(n) {
    if (n <= 0) return 0;
    if (n == 1) return 1;
    return fib(n-1) + fib(n-2);
}
print(fib(0),  "\n");   // 0
print(fib(1),  "\n");   // 1
print(fib(6),  "\n");   // 8
print(fib(10), "\n");   // 55


// ---- 12. Tables – basic -------------------------------
print("=== Tables (basic) ===\n");
tbl = [];
tbl[0] = "zero";
tbl[1] = "one";
tbl[2] = "two";
print(tbl[0], "\n");   // zero
print(tbl[1], "\n");   // one
print(tbl[2], "\n");   // two
print(typeof(tbl), "\n");  // table


// ---- 13. Tables – string keys -------------------------
print("=== Tables (string keys) ===\n");
person = [];
person["name"] = "Alice";
person["age"]  = 30;
print(person["name"], "\n");  // Alice
print(person["age"],  "\n");  // 30


// ---- 14. Tables – passed to functions -----------------
print("=== Tables in functions ===\n");
function tablesum(arr, len) {
    local s;
    s = 0;
    local k;
    k = 0;
    while (k < len) {
        s = s + arr[k];
        k = k + 1;
    }
    return s;
}
nums = [];
nums[0] = 10;
nums[1] = 20;
nums[2] = 30;
print(tablesum(nums, 3), "\n");   // 60


// ---- 15. Nested tables --------------------------------
print("=== Nested Tables ===\n");
matrix = [];
matrix[0] = [];
matrix[1] = [];
matrix[0][0] = 1;
matrix[0][1] = 2;
matrix[1][0] = 3;
matrix[1][1] = 4;
print(matrix[0][0], "\n");  // 1
print(matrix[0][1], "\n");  // 2
print(matrix[1][0], "\n");  // 3
print(matrix[1][1], "\n");  // 4


// ---- 16. totalarguments inside function ---------------
print("=== totalarguments ===\n");
function countargs(a, b, c) {
    print(totalarguments(), "\n");   // 3
}
countargs(1, 2, 3);


// ---- 17. typeof for userfunc --------------------------
print("=== typeof userfunc ===\n");
print(typeof(fact), "\n");   // userfunc


// ---- 18. sqrt / sin / cos -----------------------------
print("=== Math lib ===\n");
print(sqrt(4),   "\n");    // 2.000000
print(sqrt(2),   "\n");    // 1.414214 (approx)
print(sin(0),    "\n");    // 0.000000
print(cos(0),    "\n");    // 1.000000


// ---- 19. String equality ------------------------------
print("=== String equality ===\n");
if ("abc" == "abc") print("strings equal\n");      // printed
if ("abc" != "xyz") print("strings not equal\n");  // printed


// ---- 20. Nil equality ---------------------------------
print("=== Nil equality ===\n");
if (nil == nil)  print("nil == nil\n");   // printed
if (nil != true) print("nil != true\n"); // printed


// ---- 21. Boolean equality -----------------------------
print("=== Bool equality ===\n");
if (true  == true)  print("true == true\n");   // printed
if (false == false) print("false == false\n"); // printed
if (true  != false) print("true != false\n");  // printed


// ---- 22. Table overwrite / nil removal ----------------
print("=== Table nil removal ===\n");
del = [];
del[5] = 99;
print(del[5], "\n");   // 99
del[5] = nil;
// del[5] now removed – tablegetelem returns nullptr → prints "[5] not found"
del[5];   // access to trigger the not-found message (as a standalone expr, result discarded)


// ---- 23. Function returning table ---------------------
print("=== Function returns table ===\n");
function make_pair(u, v) {
    local p;
    p = [];
    p["first"]  = u;
    p["second"] = v;
    return p;
}
pair = make_pair(7, 13);
print(pair["first"],  "\n");   // 7
print(pair["second"], "\n");   // 13


// ---- 24. Closures / higher-order ----------------------
print("=== Higher-order / closure ===\n");
function apply(func, val) {
    return func(val);
}
function double(x) { return x * 2; }
print(apply(double, 6),  "\n");   // 12
print(apply(double, 21), "\n");   // 42


// ---- 25. Modulo edge cases ----------------------------
print("=== Modulo ===\n");
print(10 % 3,  "\n");   // 1
print(9  % 3,  "\n");   // 0
print(7  % 7,  "\n");   // 0
print(1  % 10, "\n");   // 1


// ---- End -----------------------------------------------
print("=== ALL DONE ===\n");