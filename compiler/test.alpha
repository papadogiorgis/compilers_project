
global_int = 42;
global_real = 3.14159;
global_string = "Hello, Alpha!\nThis is a \"test\" string.\t";
boolean_flag = true;
empty_value = nil;

math_result = global_int * 2 + 10 / 5 - 1 % 3;
logic_result = not (math_result == 100) and false or true;
comparison = global_int >= 40 and global_real < 4.0;

// Increment / Decrement
++global_int;
global_int--;

// 3. Control Flow: If-Else, While, Break, Continue
if (logic_result != false) {
    local temp = 10;
    
    while (temp > 0) {
        if (temp == 5) {
            --temp;
            continue;
        }
        if (temp == 2) {
            break;
        }
        temp--;
    }
} else {
    ::global_int = 0; // Global scope resolution
}

// 4. Control Flow: For Loop
for (i = 0; i < 10; i++) {
    print(i); // Assuming print will be a library function
}

// 5. Functions (Definition, Arguments, Return, Local Scope)
function calculate_sum(a, b) {
    local result = a + b;
    return result;
}

// Anonymous function assignment
multiply = function(x, y) {
    return x * y;
};

// 6. Function Calls
total = calculate_sum(10, 20);
total = multiply(total, 2);
empty_call();

// 7. Tables / Objects (Indexed and Associative)
empty_table = [];

array_table = [1, 2, 3, 4, 5];

associative_table = [
    {"name" : "Alpha"},
    {"version" : 2.0},
    {"is_active" : true}
];

// Table member access and Method calls
value = associative_table.name;
value2 = array_table[0];

// Method call syntax (callsuffix -> methodcall)
associative_table..init(1, 2, 3);